<?xml version="1.0" encoding="utf-8"?>
<form>
	<fields name="filter">
		<field
			name="search"
			type="text"
			label="COM_QUICK2CART_FILTER_SEARCH_DESC_WEIGHTS"
			description="COM_QUICK2CART_FILTER_SEARCH_DESC_WEIGHTS"
			hint="COM_QUICK2CART_FILTER_SEARCH_DESC_WEIGHTS"/>
		<field
			name="state"
			type="status"
			label="JOPTION_SELECT_PUBLISHED"
			onchange="this.form.submit();"
			extension="com_quick2cart"
			>
			<option value="">JOPTION_SELECT_PUBLISHED</option>
