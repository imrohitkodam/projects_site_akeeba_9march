<?xml version="1.0" encoding="utf-8"?>
<form >
	<fieldset addfieldpath="/administrator/components/com_quick2cart/models/fields" addrulepath="/libraries/techjoomla/model/rules" >
		<field
			name="id"
			type="text"
			size="40"
			class="inputbox"
			label="COM_QUICK2CART_FORM_LBL_ZONE_ZONE_ID"
			description="COM_QUICK2CART_FORM_DESC_ZONE_ZONE_ID"
			filter="safehtml" />

		<field
			name="name"
			type="text"
			size="40"
			class="inputbox form-control"
			label="COM_QUICK2CART_FORM_LBL_ZONE_ZONE_NAME"
			description="COM_QUICK2CART_FORM_DESC_ZONE_ZONE_NAME"
			validate="blankspace"
			class="validate-blankspace"
			required="true"
			filter="safehtml" />

		<field
			name="store_id"
			type="zonestorelist"
			class="form-select"
			label="COM_QUICK2CART_FORM_LBL_ZONE_STORE_ID"
			description="COM_QUICK2CART_FORM_DESC_ZONE_STORE_ID"
			default="0"
			filter="safehtml" />

		<field
			name="created_by"
			type="createdby"
			default=""
			label="COM_QUICK2CART_FORM_LBL_ZONE_CREATED_BY"
			description="COM_QUICK2CART_FORM_DESC_ZONE_CREATED_BY" />

		<field
			name="state"
			type="list"
			label="JSTATUS"
			description="JFIELD_PUBLISHED_DESC"
			class="inputbox form-select"
			size="1"
			default="1">
			<option value="1">JPUBLISHED</option>
			<option value="0">JUNPUBLISHED</option>
		</field>
	</fieldset>
</form>
