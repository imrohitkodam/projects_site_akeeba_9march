<?xml version="1.0" encoding="utf-8"?>
<extension version="3.0" type="module" client ="site" method="upgrade">
	<name>mod_qtc_categorylist</name>
	<author>Techjoomla</author>
	<authorEmail>extensions@techjoomla.com</authorEmail>
	<authorUrl>https://techjoomla.com</authorUrl>
	<copyright>Copyright (C) 2010 - 2025 Techjoomla. All rights reserved.</copyright>
	<license>http://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
	<creationDate>22nd Oct 2019</creationDate>
	<version>2.9.18</version>
	<description>QUICK2CART_CATEGORY_LIST_DESC</description>
	<languages folder="lang">
		<language tag="en-GB">en-GB/en-GB.mod_qtc_categorylist.ini</language>
		<language tag="en-GB">en-GB/en-GB.mod_qtc_categorylist.sys.ini</language>
	</languages>
	<files>
		<filename module="mod_qtc_categorylist">mod_qtc_categorylist.php</filename>
		<filename>index.html</filename>
		<folder>tmpl</folder>
	</files>
	<!-- Fields for Joomla 1.6.x and onwards -->
	<config name="params">
		<fields name="params">
			<fieldset name="basic">
				<field
					name="moduleclass_sfx"
					type="text"
					default=""
					label="MOD_SUFIX"
					description="MOD_QTC_CATEGORYLIST_MODULECLASS_SFX_DESC" />
				<field
					name="scroll_height"
					type="text"
					default="250"
					label="COM_QUICK2CART_SCROLL_HEIGHT_LIMIT"
					description="COM_QUICK2CART_SCROLL_HEIGHT_LIMIT_DESC" />
			</fieldset>
			<fieldset name="advanced">
				<field
					name="layout"
					type="modulelayout"
					label="JFIELD_ALT_LAYOUT_LABEL"
					description="JFIELD_ALT_MODULE_LAYOUT_DESC" />
			</fieldset>
		</fields>
	</config>

	<!--SETTING default param -->
	<config>
		<fields>
			<fieldset>
				<field name="moduleclass_sfx" default="" />
				<field name="scroll_height" default="250" />
			</fieldset>
			<fieldset name="advanced">
				<field
					name="layout"
					type="modulelayout"
					label="JFIELD_ALT_LAYOUT_LABEL"
					description="JFIELD_ALT_MODULE_LAYOUT_DESC" />
			</fieldset>
		</fields>
	</config>

</extension>
