<?xml version="1.0" encoding="utf-8"?>
<extension version="3.0" type="module" client ="site" method="upgrade">
	<name>mod_quick2cart</name>
	<author>Techjoomla</author>
	<authorEmail>extensions@techjoomla.com</authorEmail>
	<authorUrl>https://techjoomla.com</authorUrl>
	<copyright>Copyright (C) 2010 - 2025 Techjoomla. All rights reserved.</copyright>
	<license>http://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
	<creationDate>22nd Oct 2019</creationDate>
	<version>2.9.18</version>
	<description>QUICK2CART_CART_DESC</description>
	<languages folder="lang">
		<language tag="en-GB">en-GB/en-GB.mod_quick2cart.ini</language>
		<language tag="en-GB">en-GB/en-GB.mod_quick2cart.sys.ini</language>
	</languages>
	<files>
		<filename module="mod_quick2cart">mod_quick2cart.php</filename>
		<filename>index.html</filename>
		<folder>tmpl</folder>
	</files>

	<!-- Fields for Joomla 1.6.x and onwards -->
	<config name="params">
		<fields name="params">
			<fieldset name="basic">
				<field
					name="moduleclass_sfx"
					type="text"
					default=""
					label="MOD_SUFIX"
					description="MOD_SUFIX_DES" />
				<field
					name="checkout_text"
					type="text"
					default="Checkout"
					label="TEXT_CHKOUT"
					description="TEXT_CHKOUT_DES" />
				<field
					name="cache"
					type="list"
					default="0"
					label="COM_MODULES_FIELD_CACHING_LABEL"
					description="COM_MODULES_FIELD_CACHING_DESC">
					<option value="0">COM_MODULES_FIELD_VALUE_NOCACHING</option>
				</field>
				<field
					name="hideOnCartEmpty"
					type="radio"
					default="0"
					description="COM_QUICK2CART_HIDE_MOD_ON_EMPTY_DESC"
					label="COM_QUICK2CART_HIDE_MOD_ON_EMPTY"	>
					<option value="1">COM_QUICK2CART_YES</option>
					<option value="0">COM_QUICK2CART_NO</option>
				</field>
			</fieldset>
			<fieldset name="advanced">
				<field
					name="layout"
					type="modulelayout"
					label="JFIELD_ALT_LAYOUT_LABEL"
					description="JFIELD_ALT_MODULE_LAYOUT_DESC" />
			</fieldset>
		</fields>
	</config>

</extension>
