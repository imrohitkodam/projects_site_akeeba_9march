<?xml version="1.0" encoding="utf-8"?>
<extension method="upgrade" type="module" client="site" version="3.0">
	<name>Quick2Cart Personalized Products</name>
	<author>Techjoomla</author>
	<authorEmail>extensions@techjoomla.com</authorEmail>
	<authorUrl>https://techjoomla.com</authorUrl>
	<copyright>Copyright (C) 2009 - 2025 Techjoomla. All rights reserved.</copyright>
	<license>http://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
	<creationDate>3 June 2025</creationDate>
	<version>5.0.3</version>
	<description>Module to show Quick2Cart Personalized Products</description>

	<languages folder="languages">
		<language tag="en-GB">en-GB/en-GB.mod_quick2cart_personalized_products.ini</language>
		<language tag="en-GB">en-GB/en-GB.mod_quick2cart_personalized_products.sys.ini</language>
	</languages>

	<files>
		<filename module="mod_quick2cart_personalized_products">mod_quick2cart_personalized_products.php</filename>
		<filename>helper.php</filename>
		<filename>index.html</filename>
		<folder>tmpl</folder>
	</files>

	<config>
		<fields name="params">
			<fieldset name="basic">
				<field name="no_of_products_show" type="text" label="MOD_Q2C_NO_OF_PRODUCTS_TO_SHOW" default="5" description="MOD_Q2C_NO_OF_PRODUCTS_TO_SHOW_DESC" />
			</fieldset>
		</fields>
	</config>
</extension>
