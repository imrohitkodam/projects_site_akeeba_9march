<?xml version="1.0" encoding="utf-8"?>
<extension version="2.5" type="plugin" group="community" method="upgrade">
	<name>plg_community_quick2cartstore</name>
	<author>Techjoomla</author>
	<authorEmail>extensions@techjoomla.com</authorEmail>
	<authorUrl>https://techjoomla.com</authorUrl>
	<copyright>Copyright (C) 2010 - 2025 Techjoomla. All rights reserved.</copyright>
	<license>http://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
	<creationDate>2nd Jul 2025</creationDate>
	<version>5.1.0</version>
	<isapplication>true</isapplication>
	<description>PLG_COMMUNITY_QUICK2CARTSTORE_XML_DESCRIPTION</description>

	<languages folder="language/en-GB">
		<language tag="en-GB">en-GB.plg_community_quick2cartstore.ini</language>
		<language tag="en-GB">en-GB.plg_community_quick2cartstore.sys.ini</language>
	</languages>
	<files>
		<file plugin="quick2cartstore">quick2cartstore.php</file>
		<file>index.html</file>
	</files>

	<config>
		<fields name="params">
			<fieldset name="basic">
				<field name="coreapp" type="list" default="1" label="PLG_QUICK2CART_COREAPP_LBL" description="PLG_QUICK2CART_COREAPP_DESC">
					<option value="0">No</option>
					<option value="1">Yes</option>
				</field>
				<field name="position" type="list" default="sidebar-top" label="PLG_QUICK2CART_POSITION_LBL" description="PLG_QUICK2CART_POSITION_DESC">
					<option value="content">Content</option>
					<option value="sidebar-top">Sidebar Top</option>
					<option value="sidebar-bottom">Sidebar Bottom</option>
				</field>
				<field name="no_of_stores" type="text" default="2" label="PLG_QUICK2CART_NUMBER_LBL" description="PLG_QUICK2CART_NUMBER_DESC"/>
				<field name="cache" type="list" default="0" label="PLG_QUICK2CART_CACHING_LBL" description="PLG_QUICK2CART_CACHING_DESC">
						<option value="0">PLG_QUICK2CART_NO</option>
						<option value="1">PLG_QUICK2CART_YES</option>
				</field>
			</fieldset>
		</fields>
	</config>

</extension>
