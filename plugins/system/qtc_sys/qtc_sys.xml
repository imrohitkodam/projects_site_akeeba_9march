<?xml version="1.0" encoding="utf-8"?>
<extension version="3.0" type="plugin" group="system" method="upgrade">

	<name>Quick2Cart_System_Plugin</name>
	<author>Techjoomla</author>
	<authorEmail>extensions@techjoomla.com</authorEmail>
	<authorUrl>https://techjoomla.com</authorUrl>
	<copyright>Copyright (C) 2010 - 2025 Techjoomla. All rights reserved.</copyright>
	<license>http://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
	<creationDate>2nd Jul 2025</creationDate>
	<version>5.1.0</version>

	<description>QUICK2CART_SYSTEM_PLUGIN_DESC</description>

	<files>
		<filename plugin="qtc_sys">qtc_sys.php</filename>
		<filename>index.html</filename>
	</files>

	<languages folder="language" >
		<language tag="en-GB">en-GB/en-GB.plg_system_qtc_sys.ini</language>
		<language tag="en-GB">en-GB/en-GB.plg_system_qtc_sys.sys.ini</language>
	</languages>

	<!-- Fields for Joomla 1.6.x and onwards -->
	<config name="params">
		<fields name="params">
			<fieldset name="basic">
				<field name="loadBS3js" class="btn-group" type="radio" default="0" description="QTC_SYS_LOAD_BS3_JS_DESC" label="QTC_SYS_LOAD_BS3_JS" >
					<option value="1">QTC_SYS_YES</option>
					<option value="0">QTC_SYS_NO</option>
				</field>
				<field name="loadmasonryJs" class="btn-group" type="radio" default="1" description="QTC_SYS_LOAD_MASONRY_JS_DESC" label="QTC_SYS_LOAD_MASONRY_JS" >
					<option value="1">QTC_SYS_YES</option>
					<option value="0">QTC_SYS_NO</option>
				</field>

			</fieldset>
		</fields>
	</config>

</extension>
